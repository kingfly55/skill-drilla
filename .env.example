# Skill Drilla — environment configuration
# Copy this file to .env and fill in your values.

# ── LLM endpoint (any OpenAI-compatible API) ──
SKILLDRILLA_LLM_BASE_URL=https://api.openai.com/v1
SKILLDRILLA_LLM_API_KEY=sk-your-key-here

# ── Fast model — cluster labelling, arc classification, nuance extraction ──
# Called 15-25 times during analysis. Should be cheap and fast.
# Examples: gpt-4o-mini, claude-haiku-4-5, llama-3.1-8b
SKILLDRILLA_LLM_MODEL=gpt-4o-mini

# ── Heavy model — final skill file generation ──
# Called once per skill (typically 3-8 skills). Can take 5-20 minutes per call.
# Use the best model you have access to — output quality matters here.
# Examples: gpt-4o, claude-sonnet-4-5, gpt-5.4(xhigh)
SKILLDRILLA_LLM_MODEL_HEAVY=gpt-4o

# ── Embedding model for clustering (optional) ──
# Downloads automatically on first use. Default is small and free.
# Alternatives: NovaSearch/stella_en_1.5B_v5, BAAI/bge-small-en-v1.5
SKILLDRILLA_EMBEDDING_MODEL=all-MiniLM-L6-v2
