{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skill-drilla/schemas/view_summary.schema.json",
  "title": "ChatAnalysisViewSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "view_id",
    "view_name",
    "description",
    "filters",
    "recurrence_basis",
    "subagent_policy",
    "include_excluded_records",
    "source_evidence_path",
    "counts",
    "source_record_count",
    "included_record_count",
    "excluded_record_count",
    "excluded_breakdown",
    "included_breakdown"
  ],
  "properties": {
    "view_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "view_name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantic_classes", "inclusion_statuses", "session_roles", "allow_ambiguous", "include_excluded"],
      "properties": {
        "semantic_classes": {"type": "array", "items": {"type": "string"}},
        "inclusion_statuses": {"type": "array", "items": {"type": "string"}},
        "session_roles": {"type": "array", "items": {"type": "string"}},
        "allow_ambiguous": {"type": "boolean"},
        "include_excluded": {"type": "boolean"}
      }
    },
    "recurrence_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_occurrences", "distinct_evidence", "distinct_sessions", "distinct_projects"],
      "properties": {
        "raw_occurrences": {"type": "string", "minLength": 1},
        "distinct_evidence": {"type": "string", "minLength": 1},
        "distinct_sessions": {"type": "string", "minLength": 1},
        "distinct_projects": {"type": "string", "minLength": 1}
      }
    },
    "subagent_policy": {"type": "string", "minLength": 1},
    "include_excluded_records": {"type": "boolean"},
    "source_evidence_path": {"type": ["string", "null"]},
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_occurrences", "distinct_evidence", "distinct_sessions", "distinct_projects"],
      "properties": {
        "raw_occurrences": {"type": "integer", "minimum": 0},
        "distinct_evidence": {"type": "integer", "minimum": 0},
        "distinct_sessions": {"type": "integer", "minimum": 0},
        "distinct_projects": {"type": "integer", "minimum": 0}
      }
    },
    "source_record_count": {"type": "integer", "minimum": 0},
    "included_record_count": {"type": "integer", "minimum": 0},
    "excluded_record_count": {"type": "integer", "minimum": 0},
    "excluded_breakdown": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "included_breakdown": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}
  }
}
