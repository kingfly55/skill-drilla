{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skill-drilla/schemas/evidence.schema.json",
  "title": "ChatAnalysisEvidenceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "project_id",
    "project_slug",
    "session_id",
    "session_key",
    "session_role",
    "root_session_id",
    "parent_session_id",
    "lineage_state",
    "subagent_id",
    "raw_event_id",
    "raw_event_index",
    "source_file",
    "source_line",
    "semantic_class",
    "inclusion_status",
    "inclusion_rationale",
    "producer_role",
    "content_text",
    "content_format",
    "content_block_index",
    "content_block_type",
    "tool_name",
    "tool_use_id",
    "is_error",
    "parse_status",
    "record_type",
    "message_role",
    "is_sidechain",
    "ambiguity_reason",
    "metadata"
  ],
  "properties": {
    "evidence_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "project_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "project_slug": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "session_key": {"type": "string", "minLength": 1},
    "session_role": {"type": "string", "enum": ["root", "subagent", "unknown"]},
    "root_session_id": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "parent_session_id": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "lineage_state": {"type": "string", "enum": ["confirmed", "unknown"]},
    "subagent_id": {"type": ["string", "null"]},
    "raw_event_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "raw_event_index": {"type": "integer", "minimum": 0},
    "source_file": {"type": "string", "minLength": 1},
    "source_line": {"type": "integer", "minimum": 1},
    "semantic_class": {
      "type": "string",
      "enum": [
        "user_natural_language",
        "assistant_natural_language",
        "tool_call",
        "tool_result",
        "thinking",
        "protocol_meta",
        "system_operational",
        "snapshot_state",
        "unknown_ambiguous"
      ]
    },
    "inclusion_status": {
      "type": "string",
      "enum": ["included_primary", "included_secondary", "excluded_default", "ambiguous"]
    },
    "inclusion_rationale": {
      "type": "string",
      "enum": [
        "user_primary_natural_language",
        "assistant_secondary_natural_language",
        "tooling_context_only",
        "thinking_not_analysis_text",
        "protocol_or_meta_chatter",
        "system_or_operational_record",
        "snapshot_or_state_record",
        "unknown_or_ambiguous_record"
      ]
    },
    "producer_role": {"type": ["string", "null"]},
    "content_text": {"type": ["string", "null"]},
    "content_format": {"type": "string", "minLength": 1},
    "content_block_index": {"type": ["integer", "null"], "minimum": 0},
    "content_block_type": {"type": ["string", "null"]},
    "tool_name": {"type": ["string", "null"]},
    "tool_use_id": {"type": ["string", "null"]},
    "is_error": {"type": ["boolean", "null"]},
    "parse_status": {
      "type": "string",
      "enum": ["parsed", "unknown_record_shape", "invalid_json", "non_object", "blank"]
    },
    "record_type": {"type": ["string", "null"]},
    "message_role": {"type": ["string", "null"]},
    "is_sidechain": {"type": ["boolean", "null"]},
    "ambiguity_reason": {"type": ["string", "null"]},
    "metadata": {"type": "object"}
  }
}
