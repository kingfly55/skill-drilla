{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skill-drilla/schemas/report_metadata.schema.json",
  "title": "ChatAnalysisReportMetadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_title",
    "report_scope",
    "source_detector_runs",
    "ranking_method",
    "sections",
    "artifact_paths"
  ],
  "properties": {
    "report_title": {"type": "string", "minLength": 1},
    "report_scope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["detectors", "view_names", "detector_run_count", "finding_count", "scoped"]
    },
    "source_detector_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["detector", "view_name", "path", "finding_count", "diagnostics", "settings"]
      }
    },
    "ranking_method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weights", "primary_sort", "description"],
      "properties": {
        "weights": {
          "type": "object",
          "additionalProperties": {"type": "number"},
          "required": ["distinct_sessions", "raw_occurrences", "distinct_projects", "distinct_evidence"]
        },
        "primary_sort": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "description": {"type": "string", "minLength": 1}
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "heading",
          "rank",
          "finding_id",
          "detector",
          "category",
          "score",
          "recurrence",
          "recurrence_basis",
          "evidence_ids",
          "direct_user_evidence_ids",
          "supporting_context_ids",
          "source_references",
          "detector_metadata",
          "diagnostics",
          "caveats",
          "ranking_factors"
        ],
        "properties": {
          "section_id": {"type": "string", "minLength": 1},
          "heading": {"type": "string", "minLength": 1},
          "rank": {"type": "integer", "minimum": 1},
          "finding_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "detector": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "score": {"type": "number"},
          "recurrence": {"$ref": "./finding.schema.json#/properties/recurrence"},
          "recurrence_basis": {"$ref": "./finding.schema.json#/properties/recurrence_basis"},
          "evidence_ids": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          },
          "direct_user_evidence_ids": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          },
          "supporting_context_ids": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          },
          "source_references": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "evidence_id",
                "source_anchor",
                "source_file",
                "source_line",
                "project_slug",
                "session_id"
              ],
              "properties": {
                "evidence_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                "source_anchor": {"type": ["string", "null"]},
                "source_file": {"type": ["string", "null"]},
                "source_line": {"type": ["integer", "null"], "minimum": 1},
                "project_slug": {"type": ["string", "null"]},
                "session_id": {"type": ["string", "null"]}
              }
            }
          },
          "detector_metadata": {"type": "object", "additionalProperties": true},
          "diagnostics": {"type": "object", "additionalProperties": true},
          "caveats": {
            "type": "array",
            "items": {"type": "string"}
          },
          "ranking_factors": {
            "type": "object",
            "additionalProperties": true,
            "required": ["score", "weights", "weighted_metrics", "sort_tuple", "criteria_summary"]
          }
        }
      }
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": {"type": "string"},
      "required": ["output_dir", "report", "report_metadata"]
    }
  }
}
