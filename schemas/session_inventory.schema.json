{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skill-drilla/schemas/session_inventory.schema.json",
  "title": "ChatAnalysisSessionInventoryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "project_slug",
    "session_id",
    "session_key",
    "transcript_path",
    "transcript_relpath",
    "session_role",
    "lineage_state",
    "parent_session_id",
    "root_session_id",
    "observed_parent_session_key",
    "observed_root_session_key",
    "lineage_source",
    "subagent_id",
    "metadata_path",
    "transcript_format",
    "transcript_size_bytes",
    "transcript_mtime_ns"
  ],
  "properties": {
    "project_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "project_slug": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "session_key": {"type": "string", "minLength": 1},
    "transcript_path": {"type": "string", "minLength": 1},
    "transcript_relpath": {"type": "string", "minLength": 1},
    "session_role": {"type": "string", "enum": ["root", "subagent", "unknown"]},
    "lineage_state": {"type": "string", "enum": ["confirmed", "unknown"]},
    "parent_session_id": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "root_session_id": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "observed_parent_session_key": {"type": ["string", "null"]},
    "observed_root_session_key": {"type": ["string", "null"]},
    "lineage_source": {"type": "string", "minLength": 1},
    "subagent_id": {"type": ["string", "null"]},
    "metadata_path": {"type": ["string", "null"]},
    "transcript_format": {"type": "string", "const": "jsonl"},
    "transcript_size_bytes": {"type": "integer", "minimum": 0},
    "transcript_mtime_ns": {"type": "integer", "minimum": 0}
  }
}
